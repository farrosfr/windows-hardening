{
  "manifest_version": 3,
  "name": "Content Guardrail",
  "version": "1.1",
  "description": "Enforces corporate content policies.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configure Content Guardrail"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}