{
  "manifest_version": 3,
  "name": "NoA Blocker",
  "version": "1.0",
  "description": "Dynamic content filtering and redirection tool.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configure NoA Blocker"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "noablocker@farrosfr.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}